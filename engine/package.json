{
  "name": "@fm/engine",
  "version": "0.1.0",
  "description": "Pure football-sim engine + league domain logic (eligibility, config, state machine). Zero runtime dependencies by design \u2014 enforced by pnpm isolation and dependency-cruiser.",
  "type": "module",
  "exports": {
    "./types": "./engine-types.ts",
    "./rng": "./engine-rng.ts",
    "./aggregate": "./engine-aggregate.ts",
    "./eligibility": "./league-eligibility.ts",
    "./config": "./league-config.ts",
    "./state-machine": "./season-state-machine.ts",
    "./growth": "./league-growth.ts",
    "./agent": "./agent-engine.ts"
  },
  "files": [
    "agent-decision.ts",
    "agent-engine.ts",
    "agent-execution.ts",
    "agent-model.ts",
    "agent-positioning.ts",
    "agent-rng.ts",
    "calibration-reference.md",
    "engine-aggregate.ts",
    "engine-rng.ts",
    "engine-types.ts",
    "league-config.ts",
    "league-eligibility.ts",
    "league-growth.ts",
    "season-state-machine.ts",
    "stat-harness.ts"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test league-eligibility.test.ts league-growth.test.ts",
    "harness": "node stat-harness.ts",
    "realism": "node realism-harness.ts",
    "realism:ci": "node realism-harness.ts --fixture",
    "growth": "node growth-harness.ts",
    "growth:ci": "node growth-harness.ts --fixture",
    "harness-fixture": "node make-harness-fixture.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.8.0"
  }
}
