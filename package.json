{
  "name": "football-manager",
  "private": true,
  "type": "module",
  "scripts": {
    "harness": "node stat-harness.ts",
    "typecheck": "tsc --noEmit",
    "db:test:up": "docker start fm-test-pg 2>/dev/null || docker run -d --name fm-test-pg -e POSTGRES_PASSWORD=fm -e POSTGRES_DB=fm_test -p 54329:5432 postgres:16-alpine",
    "db:test:down": "docker rm -f fm-test-pg",
    "test:unit": "node --test league-eligibility.test.ts",
    "test:integration": "node --test league-integration.test.ts",
    "test:api": "node --test league-api.test.ts",
    "test:auction": "node --test league-auction.test.ts",
    "test": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:auction",
    "serve": "node league-server.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.9.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.24.1"
  }
}
